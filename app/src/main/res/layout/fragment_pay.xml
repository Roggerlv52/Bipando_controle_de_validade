<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:padding="0dp"
    android:layout_margin="0dp">

    <!-- ── Imagem de fundo preenchendo toda a tela
     android:src="@drawable/bg_pay_bipando"── -->
    <ImageView
        android:id="@+id/img_bg_pay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/magic_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Overlay escuro para garantir legibilidade dos textos ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99111C24" />

    <!-- ── Botão Fechar (X) no topo direito (com margem de segurança para Status Bar) ── -->
    <ImageButton
        android:id="@+id/btn_close_pay"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="0dp"
        android:padding="20dp"
        android:layout_marginEnd="20dp"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── ScrollView para evitar cortes em telas menores ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_close_pay"
        app:layout_constraintVertical_bias="1.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="56dp"
            android:padding="24dp">

            <!-- Coroa Premium -->
            <ImageView
                android:id="@+id/img_crown"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="#FFC107"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Título Premium -->
            <TextView
                android:id="@+id/txt_title_pay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:text="Junte-se ao Premium\nAproveite recursos\nilimitados!"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/img_crown" />

            <!-- Faixa de Usuários -->
            <TextView
                android:id="@+id/txt_stats_pay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#50000000"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="🔥 Milhares de usuários confiam"
                android:textColor="#FFC107"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txt_title_pay" />

            <!-- Lista de Recursos -->
            <LinearLayout
                android:id="@+id/layout_features"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/txt_stats_pay">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:text="Experiência 100% sem anúncios"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:text="Escaneamento e cadastro ilimitados"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:text="Notificações customizadas por produto"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:text="Categorias ilimitadas para o seu estoque"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Contêiner dos planos (Mensal / Bimestral) -->
            <LinearLayout
                android:id="@+id/layout_plans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/layout_features">

                <!-- Plano Mensal -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@android:drawable/dialog_holo_dark_frame"
                    android:backgroundTint="#24333d"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mensal"
                        android:textColor="#8ca5b2"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPriceMensal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="R$ 14,99"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Plano Bimestral -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@android:drawable/dialog_holo_dark_frame"
                    android:backgroundTint="#2e9e5b"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Semestral"
                        android:textColor="#e0f2f1"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPriceSemestral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="R$ 77,70"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Botão Iniciar Teste -->
            <Button
                android:id="@+id/btn_start_free_trial"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="10dp"
                android:layout_marginStart="10dp"
                android:backgroundTint="#FF7A00"
                android:text="Iniciar Teste GRATUITO"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/layout_plans" />

            <!-- Subtítulo informativo do teste -->
            <TextView
                android:id="@+id/txt_trial_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="30 dias grátis, depois R$ 14,99/mes"
                android:textColor="#8ca5b2"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_start_free_trial" />

            <!-- Nota de rodapé da assinatura -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="A assinatura será renovada automaticamente mensalmente ou bimestralmente até ser cancelada nas configurações da Play Store."
                android:textColor="#8ca5b2"
                android:textSize="10sp"
                app:layout_constraintTop_toBottomOf="@id/txt_trial_duration" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>