<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="0dp"
    android:fitsSystemWindows="false"
    android:padding="0dp">

    <!-- ── Imagem de fundo ── -->
    <ImageView
        android:id="@+id/img_bg_pay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/magic_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Overlay escuro para legibilidade ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99111C24" />

    <!-- ── Botão Fechar (X) ── -->
    <ImageButton
        android:id="@+id/btn_close_pay"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="20dp"
        android:background="@android:color/transparent"
        android:padding="20dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <!-- ── ScrollView ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_close_pay"
        app:layout_constraintVertical_bias="1.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:layout_marginBottom="0dp">

            <!-- Coroa Premium -->
            <ImageView
                android:id="@+id/img_crown"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:src="@android:drawable/btn_star_big_on"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#FFC107" />

            <!-- Título Premium -->
            <TextView
                android:id="@+id/txt_title_pay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/title_promotion"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/img_crown" />

            <!-- Faixa de Usuários -->
            <TextView
                android:id="@+id/txt_stats_pay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#50000000"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="@string/sub_title_promotion"
                android:textColor="#FFC107"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txt_title_pay" />

            <!-- Lista de Recursos -->
            <LinearLayout
                android:id="@+id/layout_features"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/txt_stats_pay">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:visibility="gone"
                    android:text="Experiência 100% sem anúncios"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:text="@string/text_unlimited_promotion"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:text="@string/text_customized_notification"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="12dp"
                    android:text="@string/text_unlimited_categories"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ── Contêiner dos planos ── -->
            <LinearLayout
                android:id="@+id/layout_plans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/layout_features">

                <!-- Plano Mensal -->
                <LinearLayout
                    android:id="@+id/btn_mensal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:alpha="0.6"
                    android:background="@android:drawable/dialog_holo_dark_frame"
                    android:backgroundTint="@color/bipando_color"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txt_m_select"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableEnd="@android:drawable/checkbox_off_background"
                        android:text="@string/plan_name_mensal"
                        android:textColor="#8ca5b2"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPriceMensal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="R$ 14,99"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Plano Semestral -->
                <LinearLayout
                    android:id="@+id/btn_semestral"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:alpha="0.6"
                    android:background="@android:drawable/dialog_holo_dark_frame"
                    android:backgroundTint="#2e9e5b"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txt_s_select"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableEnd="@android:drawable/checkbox_off_background"
                        android:text="@string/plan_name_semestral"
                        android:textColor="#e0f2f1"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/txtPriceSemestral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="R$ 77,70"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Banner de informação de troca de plano (visível só quando usuário ativo quer trocar) ── -->
            <LinearLayout
                android:id="@+id/layout_plan_change_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#33FFC107"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layout_plans">

                <TextView
                    android:id="@+id/txt_plan_change_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="3dp"
                    android:text=""
                    android:textColor="#FFC107"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ── Botão principal de assinatura / troca de plano ── -->
            <Button
                android:id="@+id/btn_subscribe"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="10dp"
                android:backgroundTint="#FF7A00"
                android:enabled="false"
                android:text="@string/select_plan"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/layout_plan_change_info" />

            <!-- Subtítulo informativo do teste -->
            <TextView
                android:id="@+id/txt_trial_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/information_payment"
                android:textColor="#8ca5b2"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_subscribe" />

            <!-- Nota de rodapé legal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="40dp"
                android:gravity="center"
                android:text="@string/information_subscription"
                android:textColor="#8ca5b2"
                android:textSize="10sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txt_trial_duration"
                tools:layout_editor_absoluteX="24dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>