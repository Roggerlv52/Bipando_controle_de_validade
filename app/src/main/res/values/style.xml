<resources>

    <style name="Theme.Bpd.CardView_CircleAdd">
        <item name="android:layout_width">35dp</item>
        <item name="android:layout_height">35dp</item>
    </style>
    <style name="Theme.Bpd.ImgCircleAdd">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:src">@drawable/ic_camera_dialog</item>
    </style>
	
	<style name="Theme.Bpd.TextViewFormat">
        <item name="android:layout_width">200dp</item>
        <item name="android:layout_height">wrap_content</item>
		<item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
		<item name="android:layout_marginBottom">10dp</item>
        <item name="android:maxLines">3</item>
		<item name="android:padding">3dp</item>
		<item name="android:textAlignment">center</item>
		<item name="android:textSize">14sp</item>
    </style>

	
	<style name="Theme.Bpd.FormatCardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
    </style>

    <style name="Theme.Bpd.EditTextNameFormat">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:background">@drawable/custom_edt_text</item>
        <item name="android:hint">Nome produto</item>
        <item name="android:paddingStart">60dp</item>
        <item name="android:textSize">20dp</item>
    </style>
   <style name="Theme.Bpd.EditTextNotaFormat">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:background">@drawable/custom_edt_text</item>
        <item name="android:hint">Nota</item>
        <item name="android:paddingStart">14dp</item>
		<item name="android:textColor">@color/gray</item>
        <item name="android:textSize">20dp</item>
    </style>

    <style name="Theme.Bpd.FormatButtom">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">bottom|center</item>
        <item name="android:layout_marginBottom">40dp</item>
        <item name="android:layout_marginEnd">15dp</item>
        <item name="android:layout_marginStart">15dp</item>
        <item name="android:layout_marginTop">40dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/custom_edt_text</item>
    </style>

    <style name="Theme.Bpd.Format">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">30dp</item>
		<item name="android:layout_gravity">start|center</item>
    </style>

    <style name="Theme.Bpd.ImgFormat">
        <item name="android:layout_width">45dp</item>
        <item name="android:layout_height">35dp</item>
    </style>

    <style name="Theme.Bpd.ImageView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:src">@drawable/up_picture</item>
    </style>

    <style name="MyMaterialTheme" parent="Theme.MaterialComponents.Light.NoActionBar">

        <!-- Add attributes here ic_picture -->
        <item name="colorPrimary">@color/white</item>
    </style>

</resources>